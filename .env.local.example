# Copy this file to `.env.local` for local development.
# On Vercel, set these in: Project → Settings → Environment Variables.

PROTOTYPE_USERNAME=ZoopClaims
PROTOTYPE_PASSWORD=Claims@2026

# Optional: how long the unlock cookie lasts before the visitor has to sign
# in again. In hours. Defaults to 4 if unset.
#   PROTOTYPE_SESSION_HOURS=2     # 2 hours
#   PROTOTYPE_SESSION_HOURS=8     # one workday
#   PROTOTYPE_SESSION_HOURS=0.5   # 30 minutes (fractions allowed)
PROTOTYPE_SESSION_HOURS=4
